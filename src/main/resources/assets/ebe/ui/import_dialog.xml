<?xml version="1.0" encoding="UTF-8" ?>
<ldlib2-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/Low-Drag-MC/LDLib2/refs/heads/1.21/ldlib2-ui.xsd">
    <stylesheet location="ldlib2:lss/gdp.lss"/>
    <style>
        .import-container {
            width: 100%;
            flex: 1;
            flex-direction: column;
            gap-all: 2;
        }
        .import-item {
            width: 100%;
            height: 18;
        }
        .import-empty {
            text-color: #808080;
            text-shadow: false;
        }
    </style>

    <root id="importContent" class="import-container">
        <scroller-view id="importScroller" style="width: 100%; flex: 1"/>
    </root>
</ldlib2-ui>
